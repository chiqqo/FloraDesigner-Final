# Server
PORT=5000

# MongoDB - use your Atlas connection string or a local URI
# Atlas format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=<app>
# Local format: mongodb://localhost:27017/floradesigner
MONGO_URI=mongodb://localhost:27017/floradesigner

# CORS - origin of the frontend dev server
CLIENT_ORIGIN=http://localhost:3000

# Admin credentials - validated server-side by POST /api/auth/admin/login
# Preferred: generate ADMIN_PASSWORD_HASH with:
# npm run hash-admin-password -- "your_admin_password"
# ADMIN_PASSWORD is kept as a simple demo fallback when ADMIN_PASSWORD_HASH is empty.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_before_demo
ADMIN_PASSWORD_HASH=

# Used to sign short-lived admin tokens returned after login.
# Use a long random value. ADMIN_API_KEY is kept as a compatibility fallback.
ADMIN_TOKEN_SECRET=change_this_to_a_long_random_secret
ADMIN_API_KEY=change_this_to_a_random_string
ALLOW_LEGACY_ADMIN_KEY=false

# Gemini API key - optional, for real AI image generation (server-side only, never sent to frontend)
# If missing or quota is exceeded the app falls back to curated simulated bouquet images automatically
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
